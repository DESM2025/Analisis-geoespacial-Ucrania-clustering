@article{ WOS:001522188300001,
Author = {Nikulin, Serhii and Sergieieva, Kateryna},
Title = {Assessing degradation of war-affected anthropogenic landscape using
   Sentinel-2 images},
Journal = {INTERNATIONAL JOURNAL OF REMOTE SENSING},
Year = {2025},
Volume = {46},
Number = {15},
Pages = {5732-5772},
Month = {AUG 3},
Abstract = {War causes significant changes in natural and anthropogenic landscapes
   associated with infrastructure destruction, depopulation, and reduced
   economic activity. It results in degraded agricultural lands, rewilding,
   and transforming productive lands into landscapes with limited economic
   activity. A method was developed to analyse war-induced changes in
   landscapes based on the edges of ground objects in Sentinel-2 satellite
   images using the proposed Landscape Degradation Indicator (LDI). It
   indirectly reflects human activity in the environment. Its lower values
   in wartime indicate the degradation of territory, but its growth
   reflects military activity related to logistics, fortifications, etc.
   The study covers several war-affected areas of Ukraine, while two areas
   without military action were used as a control. The results show
   degradation of territories along the front line, the extent of which
   depends on the duration and intensity of hostilities and the
   depopulation level. It was found that border areas without active
   military operations are degrading in the same way as active combat
   zones. The data obtained can be used to assess the war's environmental
   and economic impact and develop measures to restore affected areas.},

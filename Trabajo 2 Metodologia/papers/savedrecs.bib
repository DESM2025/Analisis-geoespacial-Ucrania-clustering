@inproceedings{ WOS:001310520200050,
Author = {Lu, Lizhen and Zhu, Yiqing and Gu, Jingwen},
Book-Group-Author = {IEEE},
Title = {Detecting the Impacts of Ongoing Russia-- UkraineUkraine
   ConflictonCropGrowthandHumanActivityUsingConflict on Crop Growth and
   Human Activity Using MultiMulti--ModalRemoteSensingTimeModal Remote
   Sensing Time--SeriesDataSeries Data},
Booktitle = {2024 12TH INTERNATIONAL CONFERENCE ON AGRO-GEOINFORMATICS,
   AGRO-GEOINFORMATICS 2024},
Series = {International Conference on Agro-Geoinformatics},
Year = {2024},
Pages = {258-261},
Note = {12th International Conference on Agro-Geoinformatics
   (Agro-Geoinformatics), Int Soc Agromat, Novi Sad, SERBIA, JUL 15-18,
   2024},
Abstract = {Armed conflict has negative impacts on both natural and human
   environment. In this study, Kherson state in Ukraine, a region at the
   forefront of the ongoing RussiaUkraine conflict, was chosen as the
   research area. Utilizing multi-modal remote sensing time series data
   including Sentinel-2 and VIIRS satellite images, along with ESRI 10-m
   resolution land cover data, we aim to uncover the conflict impacts on
   crop growth and human activity. Monthly and annual NDVI and night light
   mean maps were composited, and time series curves, Sen-MK trend analysis
   and violin plot were employed to detect the conflict's impacts. The
   results indicate that the conflict has led to a decline in crop growth
   and a reduction in the intensity of human activity.},

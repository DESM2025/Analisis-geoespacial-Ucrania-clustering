@ARTICLE{Lekhak2024,
	author = {Lekhak, Sagar and Ientilucci, Emmett J. and Brinkley, Anthony Wayne},
	title = {Viability of Substituting Handheld Metal Detectors with an Airborne Metal Detection System for Landmine and Unexploded Ordnance Detection},
	year = {2024},
	journal = {Remote Sensing},
	volume = {16},
	number = {24},
	pages = {},
	doi = {10.3390/rs16244732},
	url = {https://www.scopus.com/pages/publications/85213287153?origin=resultslist},
	affiliations = {Chester F. Carlson Center for Imaging Science, Rochester Institute of Technology, 54 Lomb Memorial Dr, Rochester, 14623, NY, United States; Center for Health Sciences, Forensic Science Department, Tulsa Campus, Oklahoma State University, Tulsa, 74107, OK, United States},
	abstract = {Commonly found landmines, such as the TM-62M, MON-100, and PDM-1, in the recent Russia–Ukraine war confirm the continued use of metals in munitions. Traditional demining techniques, primarily relying on handheld metal detectors and Ground Penetrating Radar (GPR) systems, remain state of the art for subsurface detection. However, manual demining with handheld metal detectors can be slow and pose significant risks to operators. Drone-based metal detection techniques offer promising solutions for rapid and effective landmine detection, but their reliability and accuracy remain a concern, as even a single missed detection can be life-threatening. This study evaluates the potential of an airborne metal detection system as an alternative to traditional handheld detectors. A comparative analysis of three distinct metal detectors for landmine detection is presented: the EM61Lite, a sensitive airborne metal detection system (tested in a pseudo-drone-based scenario); the CTX 3030, a traditional handheld all-metal detector; and the ML 3S, a traditional handheld ferrous-only detector. The comparison focuses on the number of metallic targets each detector identifies in a controlled test field containing inert landmines and UXOs. Our findings highlight the strengths and limitations of airborne metal detection systems like the EM61Lite and emphasize the need for advanced processing techniques to facilitate their practical deployment. We demonstrate how our experimental normalization technique effectively identifies additional anomalies in airborne metal detector data, providing insights for improved detection methodologies. © 2024 by the authors.},
	author_keywords = {CTX 3030; drones; EM61Lite; landmines; metal detectors; ML 3S; unexploded ordnances (UXOs); unmanned aerial vehicle (UAV)},
	keywords = {Aircraft detection; Beam forming networks; Bombs (ordnance); Drones; Explosives detection; Metal detectors; Network security; Remote sensing; Thulium alloys; Aerial vehicle; Airborne metals; CTX 3030; Em61lite; Handhelds; Landmine; ML 3s; Unexploded ordnance; Unmanned aerial vehicle; Landmine detection},
	correspondence_address = {S. Lekhak; Chester F. Carlson Center for Imaging Science, Rochester Institute of Technology, Rochester, 54 Lomb Memorial Dr, 14623, United States; email: sl3088@rit.edu},
	publisher = {Multidisciplinary Digital Publishing Institute (MDPI)},

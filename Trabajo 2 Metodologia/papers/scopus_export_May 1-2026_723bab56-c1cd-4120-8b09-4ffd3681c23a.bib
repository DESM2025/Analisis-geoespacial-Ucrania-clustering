@CONFERENCE{Hsu2024,
	author = {Hsu, Faye},
	title = {Analyzing Vegetation Damage from the Russo-Ukrainian War: a Geographic Information System & Remote Sensing-Based Analysis},
	year = {2024},
	journal = {URTC 2024 - 2024 IEEE MIT Undergraduate Research Technology Conference, Proceedings},
	pages = {},
	doi = {10.1109/URTC65039.2024.10937587},
	url = {https://www.scopus.com/pages/publications/105002704654?origin=resultslist},
	abstract = {This study investigates the environmental impacts of the Russo-Ukrainian War with an emphasis on vegetation damage: an area of research that remains relatively unexplored in context to the ongoing war. Leveraging Geographic Information System (GIS) and Remote Sensing techniques, satellite imagery was analyzed to provide a comprehensive insight of vegetation harm with an additional focus on quantification. Changes in vegetation cover data were synthesized with respect to conflict data in order to analyze any potential correlational or causational links. The findings highlight extensive vegetation damage in war-impacted areas on quantitative metrics, substantiating findings with scientific validity. Recognizing the effects of military activities on vegetation is vital for the protection of biodiversity, ecosystems, forests, and the climate. By evaluating the extent of vegetation damage, insights are provided on maintaining environmental health in the face of warfare, informing conservation strategies in the restoration of regions affected by conflict-induced damage. The utilization of GIS and remote sensing methods offers a baseline for monitoring future environmental changes and vegetation cover trends, aiding in the development of targeted strategies for mitigation and recovery efforts. © 2024 IEEE.},
	keywords = {Environmental health; Geographic information; In contexts; Military activities; Quantitative metric; Remote sensing techniques; Remote-sensing; Synthesised; Vegetation cover; Vegetation damage; Vegetation mapping},

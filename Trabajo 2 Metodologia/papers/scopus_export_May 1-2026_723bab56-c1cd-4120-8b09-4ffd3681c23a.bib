	author = {Zhao, Yulan and Ma, Xiaoxue and Qiao, Weiliang},
	title = {Investigating spatial-temporal patterns of the important disruptions associated with China's LNG shipping network},
	year = {2026},
	journal = {Journal of Cleaner Production},
	volume = {538},
	pages = {},
	doi = {10.1016/j.jclepro.2025.147368},
	url = {https://www.scopus.com/pages/publications/105025882683?origin=resultslist},
	affiliations = {School of Maritime Economics and Management, Dalian Maritime University, Dalian, China; Public Administration and Humanities College, Dalian Maritime University, Dalian, China; Marine Engineering College, Dalian Maritime University, Dalian, China},
	abstract = {Maritime shipping serves as the primary mode of transporting liquefied natural gas (LNG) due to the significant regional disparities of LNG distribution. However, the shipping industry is subject to various disruptions. In this study, disruptions associated with China's LNG import shipping network are investigated. For this purpose, the data is first collected to understand the disruptions during 2015–2024. To evaluate the disruption information, the collected disruption information is mathematically processed by developing a data-driven particle swarm optimization and back propagation neural network (PSO-BP) algorithm. The various disruption information is input into the input layer, and through the calculation of the hidden layer and output layer of the BP neural network, which is aggregated into a comprehensive value. Then, the comprehensive disruption value is geographically and visually presented with the application of ArcGIS. Additionally, the key disruption aspects are identified by developing an obstacle degree model. Finally, the results are described from three aspects: temporal changes, spatial distribution, and key disruption aspects. More importantly, the disturbed level of the network is compared and analyzed before and after the Russia-Ukraine conflict. The results of this study provide practical insights that can help decision-makers promote the development of the LNG shipping network. © 2025 Elsevier Ltd.},
	author_keywords = {China'S LNG shipping network; Disruptions analysis; Multisource data fusion; Obstacle degree model; PSO-BP},
	keywords = {Backpropagation; Data flow analysis; Data fusion; Electric power system interconnection; Geographic information systems; Liquefied natural gas; Multilayer neural networks; Natural gas transportation; Network layers; Tankers (ships); Back-propagation neural networks; China'S liquefied natural gas shipping network; Disruption analysis; Multisource data; Multisource data fusion; Obstacle degree model; Particle swarm; Particle swarm optimization and back propagation neural network; Spatial temporals; Swarm optimization; Particle swarm optimization (PSO)},
	correspondence_address = {W. Qiao; Marine Engineering College, Dalian Maritime University, Dalian, China; email: xiaoqiao_fang@dlmu.edu.cn},
	publisher = {Elsevier Ltd},
	issn = {09596526},
	coden = {JCROE},

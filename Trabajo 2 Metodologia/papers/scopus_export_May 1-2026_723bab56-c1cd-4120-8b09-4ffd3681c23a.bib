@ARTICLE{Ostapenko20251129,
	author = {Ostapenko, Pavlo and Bonchkovskyi, Oleksandr and Semenikhin, Volodymyr and McCarthy, Killian and Dolfsma, Wilfred},
	title = {From Battlefields to Blooming Fields: The Economic Costs of Restoring Ukraine’s War-Damaged Agricultural Soil},
	year = {2025},
	journal = {Journal of Economic Issues},
	volume = {59},
	number = {4},
	pages = {1129 - 1134},
	doi = {10.1080/00213624.2025.2575153},
	url = {https://www.scopus.com/pages/publications/105020777770?origin=resultslist},
	affiliations = {Taras Shevchenko National University of Kyiv, Ukraine; Ukrainian Researchers Society, Kyiv, Ukraine; Kyiv School of Economics, Ukraine; Radboud Universiteit Nijmegen, Gelderland, Nijmegen, Netherlands; Open University, Netherlands},
	abstract = {The Russia-Ukraine war has significantly disrupted global food supplies. The assumption is that after the war, production can return to normal. But is this true? This study estimates the damage to Ukraine’s agricultural soil and the economic costs of restoring it to its pre-war fertility. Focusing on Kharkiv Oblast, we use high-resolution satellite imagery to identify 162,294 hectares of battle-damaged land and estimate that restoring this one region will cost $2 billion. Assuming that Kharkiv is representative, the implication is that it will cost about $20 billion—about one-fifth of Ukraine’s pre-war GDP—to restore all of Ukraine’s soil after the war. Given the scale of the demand on Ukraine’s public finances we conclude that it will be quite some time before Ukraine’s agricultural sector returns to its pre-war levels, and we warn policymakers not to assume that once the fighting ends, farmers can return, and the grain will flow. © 2025, Journal of Economic Issues / Association for Evolutionary Economics.},
	author_keywords = {soil damage; soil repair; Ukraine; war damage},
